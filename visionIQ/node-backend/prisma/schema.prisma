generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum JobStatus {
  QUEUED
  EXTRACTING
  PROCESSING
  EVALUATING
  DONE
  FAILED
}

enum SessionStatus {
  ACTIVE
  CLOSED
  EVALUATED
}

enum RuleSource {
  TEMPLATE
  CUSTOM
  AI_GENERATED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

// ============ USER ============

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  cameras  Camera[]
  jobs     Job[]
  rules    Rule[]
  profiles Profile[]

  @@map("user")
  @@index([email])
}

// ============ CAMERA ============

model Camera {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  location    String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  jobs     Job[]
  sessions Session[]
  rules    Rule[]
  profiles Profile[]
  events   Event[]

  @@map("camera")
  @@index([userId])
}

// ============ JOB ============

model Job {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cameraId       String?   @map("camera_id")
  camera         Camera?   @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  status         JobStatus @default(QUEUED)
  videoUrl       String    @map("video_url")
  videoDurationS Float?    @map("video_duration_s")
  fpsSetting     Float     @default(1.0) @map("fps_setting")
  totalFrames    Int?      @map("total_frames")
  motionFrames   Int?      @map("motion_frames")
  framesDone     Int       @default(0) @map("frames_done")
  sessionsCount  Int       @default(0) @map("sessions_count")
  eventsCount    Int       @default(0) @map("events_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  sessions Session[]
  events   Event[]

  @@map("job")
  @@index([userId])
  @@index([cameraId])
  @@index([status])
}

// ============ SESSION ============

model Session {
  id          String        @id @default(uuid())
  jobId       String        @map("job_id")
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cameraId    String        @map("camera_id")
  camera      Camera        @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  startedAt   DateTime      @map("started_at")
  endedAt     DateTime?     @map("ended_at")
  status      SessionStatus @default(ACTIVE)
  timeline    Json          @default("[]")
  personsSeen String[]      @map("persons_seen")
  evalCount   Int           @default(0) @map("eval_count")
  lastEvalAt  DateTime?     @map("last_eval_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  events Event[]

  @@map("session")
  @@index([cameraId, status])
  @@index([jobId])
}

// ============ RULE ============

model Rule {
  id        String     @id @default(uuid())
  cameraId  String     @map("camera_id")
  camera    Camera     @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleText  String     @map("rule_text")
  source    RuleSource
  packName  String?    @map("pack_name")
  enabled   Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("rule")
  @@index([cameraId])
  @@index([userId])
}

// ============ PROFILE ============

model Profile {
  id           String   @id @default(uuid())
  cameraId     String   @map("camera_id")
  camera       Camera   @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  role         String?
  isRegistered Boolean  @default(true) @map("is_registered")
  faceVectorId String?  @map("face_vector_id")
  photoUrl     String?  @map("photo_url")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("profile")
  @@index([cameraId])
  @@index([userId])
}

// ============ EVENT ============

model Event {
  id              String   @id @default(uuid())
  jobId           String   @map("job_id")
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sessionId       String?  @map("session_id")
  session         Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  cameraId        String   @map("camera_id")
  camera          Camera   @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  timestamp       DateTime
  videoOffsetS    Float    @map("video_offset_s")
  personsInvolved String[] @map("persons_involved")
  ruleMatched     String?  @map("rule_matched")
  reasoning       String?
  severity        Severity
  description     String
  timelineWindow  Json?    @map("timeline_window")
  thumbnailUrl    String?  @map("thumbnail_url")
  clipUrl         String?  @map("clip_url")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("event")
  @@index([jobId])
  @@index([cameraId, timestamp])
  @@index([personsInvolved], type: Gin)
  @@index([severity])
}
