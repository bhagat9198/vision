# =============================================================================
# img-analyse-backend Environment Configuration
# =============================================================================
# Copy this file to .env and update the values as needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4001

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/img_analyse

# -----------------------------------------------------------------------------
# Master API Key (required for org registration)
# -----------------------------------------------------------------------------
MASTER_API_KEY=master-key-change-me-in-production

# -----------------------------------------------------------------------------
# Qdrant - Vector Database
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Redis (shared with api-node-backend)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# CompreFace - Face Detection & Recognition
# -----------------------------------------------------------------------------
COMPREFACE_URL=http://localhost:8000
COMPREFACE_RECOGNITION_API_KEY=your-recognition-api-key
COMPREFACE_DETECTION_API_KEY=your-detection-api-key

# -----------------------------------------------------------------------------
# Python Sidecar - Fallback Detection & Alignment
# -----------------------------------------------------------------------------
PYTHON_SIDECAR_URL=http://localhost:4002

# -----------------------------------------------------------------------------
# Face Processing Defaults (can be overridden by admin settings)
# -----------------------------------------------------------------------------
# Minimum face size in pixels (faces smaller than this are skipped)
FACE_MIN_SIZE_PX=60

# Minimum detection confidence (0.0 to 1.0)
FACE_MIN_CONFIDENCE=0.7

# Skip faces with extreme angles (>45 degrees)
FACE_SKIP_EXTREME_ANGLES=true

# Vector dimension for embeddings (depends on CompreFace model)
FACE_EMBEDDING_DIMENSION=512

# -----------------------------------------------------------------------------
# Search Defaults
# -----------------------------------------------------------------------------
# Default number of results to return
SEARCH_DEFAULT_TOP_K=100

# Minimum similarity score (0.0 to 1.0)
SEARCH_MIN_SIMILARITY=0.6

# Embedding cache TTL in seconds (30 minutes)
EMBEDDING_CACHE_TTL_SECONDS=1800

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

