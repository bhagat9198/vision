// =============================================================================
// Prisma Schema - img-analyse-backend
// =============================================================================
// Multi-tenant face analysis service with organization-based configuration
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum FaceDetectionMode {
  RECOGNITION_ONLY
  DETECTION_THEN_RECOGNITION
}

enum ImageSourceMode {
  URL
  MULTIPART
  SHARED_STORAGE
}

enum FaceRecognitionProvider {
  COMPREFACE
  INSIGHTFACE
}

// ============ MODELS ============

/// Organization - represents a tenant in the multi-tenant system
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // === CompreFace Settings ===
  comprefaceUrl               String?
  comprefaceRecognitionApiKey String?
  comprefaceDetectionApiKey   String?

  // === Detection Settings ===
  faceDetectionMode FaceDetectionMode @default(RECOGNITION_ONLY)
  imageSourceMode   ImageSourceMode   @default(URL)
  sharedStoragePath String?

  // === Quality Filters ===
  minConfidence     Float   @default(0.5)
  minSizePx         Int     @default(60)
  skipExtremeAngles Boolean @default(true)

  // === Search Settings ===
  searchDefaultTopK   Int   @default(50)
  searchMinSimilarity Float @default(0.6)

  // === Cache Settings ===
  embeddingCacheTtlSeconds Int @default(1800) // 30 min

  // === Python Sidecar ===
  pythonSidecarUrl        String?
  enableFallbackDetection Boolean @default(true)
  enableAlignment         Boolean @default(true)

  // === Face Recognition Provider ===
  // COMPREFACE: Uses external CompreFace service (requires comprefaceUrl)
  // INSIGHTFACE: Uses Python sidecar's built-in InsightFace (self-contained)
  faceRecognitionProvider FaceRecognitionProvider @default(COMPREFACE)
  insightfaceModel        String?  // e.g., 'buffalo_l', 'buffalo_s', 'antelopev2'

  // === Relations ===
  apiKeys ApiKey[]
  eventImageStatuses EventImageStatus[]
  eventVideoStatuses EventVideoStatus[]

  @@map("organizations")
}

/// ApiKey - authentication keys for organizations
model ApiKey {
  id        String    @id @default(uuid())
  orgId     String
  key       String    @unique
  name      String    @default("Default")
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([orgId])
  @@map("api_keys")
}

/// User - system administrators
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ============ TRACKING MODELS ============

enum IndexingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// EventImageStatus - tracks indexing status of individual images
model EventImageStatus {
  id        String         @id @default(uuid())
  eventId   String
  photoId   String
  eventSlug     String?
  orgId         String
  status        IndexingStatus @default(PENDING)
  isActive      Boolean        @default(true)
  error         String?
  imageUrl      String?        // URL to display the image
  facesDetected Int            @default(0)
  facesIndexed  Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Video Relation
  sourceVideoId String?
  videoTimestamp Float?
  video EventVideoStatus? @relation(fields: [sourceVideoId], references: [id], onDelete: SetNull)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([eventId, photoId])
  @@index([eventId])
  @@index([eventSlug])
  @@index([orgId])
  @@map("event_image_statuses")
}

/// EventVideoStatus - tracks video processing status
model EventVideoStatus {
  id        String         @id @default(uuid())
  eventId   String
  videoId   String         // User provided or generated
  eventSlug String?
  orgId     String
  status    IndexingStatus @default(PENDING)
  isActive  Boolean        @default(true)
  error     String?
  videoUrl  String?        // URL to stream/download the video (if applicable)
  
  // Stats
  durationSec    Float     @default(0)
  framesExtracted Int      @default(0)
  facesFound     Int       @default(0)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Relation to extracted frames
  frames EventImageStatus[]

  @@unique([eventId, videoId])
  @@index([eventId])
  @@index([eventSlug])
  @@index([orgId])
  @@map("event_video_statuses")
}