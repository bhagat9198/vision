{
  "name": "img-analyse-backend",
  "version": "1.0.0",
  "description": "High-speed face detection, embedding extraction, and similarity search service",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --max-old-space-size=4096 src/server.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=4096 dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "face-detection",
    "face-recognition",
    "vector-search",
    "compreface",
    "qdrant"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/json-stringify-safe": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "json-stringify-safe": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.0.0",
    "sharp": "^0.33.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.10.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^8.57.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
